package = ncurses

headers = ncurses.h term.h
headerFilter = ncurses.h curses.h term.h

compilerOpts.osx = -I/opt/homebrew/opt/ncurses/include
linkerOpts.osx  = -L/opt/homebrew/opt/ncurses/lib -lncurses

compilerOpts.linux = -I/usr/include -I/usr/include/x86_64-linux-gnu
linkerOpts.linux = -lncurses
